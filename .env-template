# ==========================================
# 0. PARÁMETROS GENERALES
# ==========================================
TEMPERATURE=0.2
MAX_TOKENS=500
CHUNK_SIZE=200
CHUNK_OVERLAP=50

# Número de documentos a recuperar
TOP_K=5

# ==========================================
# 1. CONFIGURACIÓN DEL LLM (GROQ)
# ==========================================
LLM_PROVIDER=groq
# Tu clave actual (CUIDADO: No compartir)
LLM_API_KEY=
LLM_BASE_URL=

# Modelos seleccionados para Groq
MODELO_LLM=
MODELO_FAST=

# ==========================================
# 2. MODELOS VECTORIALES (Embeddings)
# ==========================================
# Este modelo debe coincidir con el usado en la ingesta (01_Ingesta...)
MODELO_EMBEDDINGS=

# Reranker (Opcional, usado si activas re-ranking)
MODELO_RERANKER=

# ==========================================
# 3. CONFIGURACIÓN CHROMA DB
# ==========================================
# Alineado con tus scripts 01 y 03
DB_PATH=
COLLECTION_NAME=

# ==========================================
# 4. EXTRAS
# ==========================================
GOOGLE_API_KEY=
